# Copy to .env. DEMO_MODE=true runs the full pipeline with simulated phases
# (no creds needed) so you can see the UI end-to-end immediately.
DEMO_MODE=true

# GitHub (used when DEMO_MODE=false for fork/clone/PR)
GITHUB_TOKEN=

# LambdaTest / Kane (used when DEMO_MODE=false)
LT_USERNAME=
LT_ACCESS_KEY=

# Anthropic (agent synthesis + repair, used when DEMO_MODE=false)
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# Committed test style:
#   as_is   = commit Kane's testmu-dialect Playwright-Python export verbatim (no Anthropic key)
#   vanilla = LLM agent translates to dependency-free Playwright (needs ANTHROPIC_API_KEY)
TEST_STYLE=as_is

# Execution mode:
#   true  = run the pipeline in-process (local dev; needs kane-cli, gh, Chrome/LT)
#   false = the API only dispatches a GitHub Actions job that runs the pipeline
#           and streams events back. Used in hosted deployments. See DEPLOY.md.
LOCAL_EXECUTION=true
# Only used when LOCAL_EXECUTION=false:
RUNNER_REPO=            # owner/repo hosting .github/workflows/pipeline.yml
RUNNER_REF=main         # branch the workflow runs on (must be the default branch)
PUBLIC_BASE_URL=        # this API's public URL — where the CI job posts events
INGEST_SECRET=          # shared secret; same value as the GitHub Actions secret

# Kane execution mode (applies wherever the pipeline actually runs):
#   false = local headless Chrome (needs Chrome installed; ~8 concurrent max via CDP ports)
#   true  = run on the LambdaTest grid via ws-endpoint — no local Chrome
KANE_CLOUD=false

# Concurrent Kane verifications in P6. Local cap ~8 (CDP ports 9222-9230); higher in cloud mode.
KANE_CONCURRENCY=6

# Where the worker clones forks
WORKSPACE_DIR=./.workspaces

# CORS origin for the frontend
FRONTEND_ORIGIN=http://localhost:3000
